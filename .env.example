# =========================
# ENV INFO
# =========================
VITE_ENV=production
VITE_APP_NAME=NILL
VITE_APP_URL=https://nillai.de

# =========================
# BACKEND
# =========================
VITE_API_URL=https://api.nillai.de

# =========================
# AUTH / OAUTH (PUBLIC ONLY)
# =========================
# Google OAuth Client ID — safe to commit (public, no secret)
VITE_GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# =========================
# FEATURES / FLAGS
# =========================
VITE_ENABLE_GMAIL=true
VITE_ENABLE_AI=true

# =========================
# ANALYTICS
# =========================
# GA4 Measurement ID — set in CI/CD env or hosting platform (e.g. Vercel env vars)
# Do NOT commit the real ID to .env; it will appear in git history.
VITE_GA_ID=G-XXXXXXXXXX

# =========================
# DEBUGGING
# =========================
VITE_LOG_LEVEL=info
